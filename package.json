{
  "name": "swagger-api-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for generating API layers from Swagger/OpenAPI specifications",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "swagger-api-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build"
  },
  "keywords": [
    "mcp",
    "swagger",
    "openapi",
    "api",
    "code-generation",
    "react",
    "typescript",
    "vite",
    "tanstack-query",
    "react-hook-form",
    "zod"
  ],
  "author": "Swagger MCP",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.7.0",
    "openapi-types": "^12.1.3",
    "prettier": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
